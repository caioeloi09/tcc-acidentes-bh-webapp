# Ignorar arquivos de build e dependências
**/node_modules/
**/dist/
**/build/
**/.gradle/
**/out/

# Ignorar arquivos de IDE
**/.idea/
**/.vscode/
**/*.iml
**/.DS_Store

# Ignorar arquivos de ambiente
**/.env
**/.env.local

# Ignorar logs
**/logs/
**/*.log

# Ignorar dados (manter apenas estrutura e gitkeep)
**/data/*.db
**/data/*.csv
!**/data/.gitkeep
# Backend Maven build output
backend/target/

# Ignorar arquivos temporários
**/*.tmp
**/*.swp
**/*.bak
